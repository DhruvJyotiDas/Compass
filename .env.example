# Copy to .env and fill in your values
DOMAIN=yourdomain.com

# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# ── AI inference (OpenAI-compatible) ─────────────────────────────────────────
# ONE variable switches the provider for every AI agent. Points at the self-hosted
# Qwen2.5-14B-Instruct-AWQ endpoint (vLLM — OpenAI-compatible).
# Leave LLM_BASE_URL empty to run the deterministic offline MOCK (no GPU needed).
LLM_BASE_URL=http://163.128.34.19:8000/v1
LLM_MODEL=/root/test/models/Qwen2.5-14B-Instruct-AWQ
LLM_API_KEY=sk-no-auth              # vLLM ignores this by default
# LLM_ENABLED=true                  # set false to force mock even if a URL is set

# Legacy local LLM (Ollama) — kept for back-compat, unused when LLM_BASE_URL is set
GEMMA_MODEL=gemma4:e2b

# Security
CHANNEL_HMAC_SECRET=change-me-strong-secret-32-chars
ADMIN_SECRET=change-me-admin-secret

# CRM auth — JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-long-random-jwt-secret

# Frontend (these are built into the Next.js image)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_CHANNEL_URL=https://channel.yourdomain.com
