# Compass CRM — Caddyfile
# Replace {$DOMAIN} with your actual domain via env var

app.{$DOMAIN} {
    reverse_proxy frontend:3000
}

api.{$DOMAIN} {
    reverse_proxy crm-api:8000
    # Allow large SSE connections
    header_up Connection keep-alive
}

channel.{$DOMAIN} {
    # Public on purpose — proves two services talk over real internet
    reverse_proxy channel:8001
}
