# Production build env (tracked in git — unlike .env.local).
#
# These are baked into the client bundle at `next build` time. They MUST be
# relative paths so the browser calls the API on the SAME origin and scheme the
# page was served from (https://dhruvjyoti.com/api). Never put an absolute
# http://<ip> URL here: an HTTPS page fetching an HTTP/IP URL is blocked by the
# browser as a mixed-content "network error" (this broke login once — see README).
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CHANNEL_URL=/channel
